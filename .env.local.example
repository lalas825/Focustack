# ─── SUPABASE ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aqui
# Ver: Supabase Dashboard > Authentication > Providers > Google

# ─── TELEGRAM (Cowork Integration) ───────────────────
# 1. Message @BotFather on Telegram -> /newbot -> follow instructions
# 2. Copy the token here
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=

# 3. Message your new bot /start, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 4. Find your chat_id in the response
NEXT_PUBLIC_TELEGRAM_CHAT_ID=
